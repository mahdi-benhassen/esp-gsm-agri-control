menu "Relay Control Configuration"

    config RELAY_1_GPIO
        int "Relay 1 GPIO"
        default 40
        help
            GPIO pin for Relay 1. KC868-A2v3 default: GPIO40.

    config RELAY_2_GPIO
        int "Relay 2 GPIO"
        default 39
        help
            GPIO pin for Relay 2. KC868-A2v3 default: GPIO39.

    config RELAY_ACTIVE_LOW
        bool "Relays are Active-Low"
        default y
        help
            If set, GPIO LOW activates relay; HIGH activates otherwise.

    config RELAY_MAX_ON_TIME_SEC
        int "Relay Max On Time (Seconds)"
        default 3600
        help
            Maximum time a relay can stay active on timed operation.

endmenu
