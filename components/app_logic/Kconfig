menu "Application Logic Configuration"

    config APP_LOGIC_TASK_STACK_SIZE
        int "App Logic Task Stack Size"
        default 4096

    config APP_LOGIC_TASK_PRIORITY
        int "App Logic Task Priority"
        default 5

    config APP_PUBLISH_STATUS_INTERVAL_SEC
        int "System Status Publish Interval (seconds)"
        default 300
        help
            How often to publish system health parameters to MQTT status topic.

    config APP_IRRIGATION_HYSTERESIS_PCT
        int "Auto-irrigation re-arm hysteresis percentage"
        range 0 50
        default 5
        help
            Auto-irrigation starts below the configured moisture threshold and
            re-arms only after moisture rises at least this many percentage
            points above that threshold.

endmenu
